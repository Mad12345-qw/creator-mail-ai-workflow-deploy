{
  "version": "2026-07-09",
  "rules": [
    {
      "id": "system-delivery-notice",
      "name": "System delivery notice",
      "match": ["delivery status notification", "undelivered mail", "mail delivery failed", "message delivery failed", "email forwarding verification", "email verification notification"],
      "action": "no_reply",
      "notes": "Record only."
    },
    {
      "id": "stop-contact",
      "name": "Stop contacting request",
      "match": ["unsubscribe", "remove me", "stop contacting", "do not follow up"],
      "action": "record_only",
      "notes": "Update creator contact status."
    }
  ]
}
